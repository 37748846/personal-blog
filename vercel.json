{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "framework": null,
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "lrbar.com"
        }
      ],
      "destination": "https://www.lrbar.com/:path*",
      "statusCode": 301
    }
  ],
  "regions": ["hkg1"]
}
