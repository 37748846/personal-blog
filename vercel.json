{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "framework": null,
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/",
      "destination": "https://www.lrbar.com/",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "destination": "https://www.lrbar.com/:path*",
      "statusCode": 301
    }
  ],
  "regions": ["hkg1"]
}
