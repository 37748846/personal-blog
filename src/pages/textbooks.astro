---
import Main from "@/layouts/Main.astro";
---

<Main pageTitle="小初高教材" pageDesc="提供小学、初中、高中各科教材PDF下载">
  <section class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-12">
    <h1 class="mb-8 text-4xl font-bold text-accent sm:text-5xl">小初高教材</h1>

    <p class="mb-8 text-lg text-skin-muted">
      提供小学、初中、高中各科教材PDF下载
    </p>

    <!-- Quick Navigation -->
    <div class="mb-8 rounded-lg border border-border bg-surface p-4">
      <nav class="flex flex-wrap justify-center gap-4">
        <a
          href="#categories"
          class="px-4 py-2 bg-muted text-foreground rounded-lg hover:bg-accent/10 transition-colors"
        >
          📚 教材分类
        </a>
        <a
          href="#download"
          class="px-4 py-2 bg-muted text-foreground rounded-lg hover:bg-accent/10 transition-colors"
        >
          ⬇️ 下载方式
        </a>
        <a
          href="#notice"
          class="px-4 py-2 bg-muted text-foreground rounded-lg hover:bg-accent/10 transition-colors"
        >
          ⚠️ 使用说明
        </a>
      </nav>
    </div>

    <!-- 数据来源 -->
    <div class="mb-8 rounded-lg border border-border bg-surface p-6">
      <h2 class="mb-4 text-2xl font-bold text-accent">数据来源</h2>
      <p class="mb-2 text-skin-muted">
        <strong>GitHub 仓库：</strong>
        <a
          href="https://github.com/TapXWorld/ChinaTextbook"
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent hover:underline"
        >
          ChinaTextbook
        </a>
      </p>
      <p class="text-skin-muted">
        <strong>Star数：</strong> 70,236+ | <strong>Fork数：</strong> 15,704+
      </p>
    </div>

    <!-- Categories -->
    <div id="categories" class="mb-8 rounded-lg border border-border bg-surface p-6">
      <h2 class="mb-4 text-2xl font-bold text-accent">教材分类</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-6 rounded-lg border border-border">
          <div class="flex items-start mb-4">
            <div class="text-4xl mr-4">📚</div>
            <div>
              <h3 class="text-xl font-semibold mb-2">小学教材</h3>
              <p class="text-skin-muted">小学1-6年级各科教材</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">语文</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">数学</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">英语</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">科学</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">道德与法治</span>
          </div>
        </div>

        <div class="p-6 rounded-lg border border-border">
          <div class="flex items-start mb-4">
            <div class="text-4xl mr-4">📖</div>
            <div>
              <h3 class="text-xl font-semibold mb-2">初中教材</h3>
              <p class="text-skin-muted">初中7-9年级各科教材</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">语文</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">数学</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">英语</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">物理</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">化学</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">生物</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">历史</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">地理</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">政治</span>
          </div>
        </div>

        <div class="p-6 rounded-lg border border-border">
          <div class="flex items-start mb-4">
            <div class="text-4xl mr-4">📕</div>
            <div>
              <h3 class="text-xl font-semibold mb-2">高中教材</h3>
              <p class="text-skin-muted">高中10-12年级各科教材</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">语文</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">数学</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">英语</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">物理</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">化学</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">生物</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">历史</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">地理</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">政治</span>
          </div>
        </div>

        <div class="p-6 rounded-lg border border-border">
          <div class="flex items-start mb-4">
            <div class="text-4xl mr-4">🎓</div>
            <div>
              <h3 class="text-xl font-semibold mb-2">大学教材</h3>
              <p class="text-skin-muted">大学各专业教材</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">计算机</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">数学</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">物理</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">化学</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">经济</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">管理</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">文学</span>
            <span class="px-3 py-1 bg-accent/10 text-accent rounded-full text-sm">法学</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Download Section -->
    <div id="download" class="mb-8 rounded-lg border border-border bg-surface p-6">
      <h2 class="mb-4 text-2xl font-bold text-accent">下载方式</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="p-6 rounded-lg border border-border">
          <h3 class="text-xl font-semibold mb-4">方式1：GitHub 官方下载</h3>
          <p class="text-skin-muted mb-4">
            直接从 GitHub 仓库下载完整的教材文件
          </p>
          <a
            href="https://github.com/TapXWorld/ChinaTextbook"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-6 py-3 bg-accent text-background rounded-lg hover:bg-accent/90 transition-colors"
          >
            访问 GitHub 仓库
          </a>
        </div>

        <div class="p-6 rounded-lg border border-border">
          <h3 class="text-xl font-semibold mb-4">方式2：国内加速下载 ⚡</h3>
          <p class="text-skin-muted mb-4">
            使用国内 GitHub 加速服务，下载速度更快
          </p>
          <div class="space-y-2">
            <a
              href="https://ghproxy.com/https://github.com/TapXWorld/ChinaTextbook"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full px-4 py-2 bg-accent text-background rounded-lg hover:bg-accent/90 transition-colors text-center"
            >
              ghproxy.com 加速
            </a>
            <a
              href="https://ghps.cc/https://github.com/TapXWorld/ChinaTextbook"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full px-4 py-2 bg-accent text-background rounded-lg hover:bg-accent/90 transition-colors text-center"
            >
              ghps.cc 加速
            </a>
            <a
              href="https://gitclone.com/github.com/TapXWorld/ChinaTextbook"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full px-4 py-2 bg-accent text-background rounded-lg hover:bg-accent/90 transition-colors text-center"
            >
              gitclone.com 加速
            </a>
          </div>
        </div>

        <div class="p-6 rounded-lg border border-border">
          <h3 class="text-xl font-semibold mb-4">方式3：Git 克隆</h3>
          <p class="text-skin-muted mb-4">
            使用 Git 命令克隆整个仓库到本地
          </p>
          <div class="space-y-2">
            <div class="bg-muted p-4 rounded-lg text-sm">
              <div class="mb-2 font-semibold">官方地址：</div>
              <code class="text-accent">git clone https://github.com/TapXWorld/ChinaTextbook.git</code>
            </div>
            <div class="bg-muted p-4 rounded-lg text-sm">
              <div class="mb-2 font-semibold">加速地址：</div>
              <code class="text-accent">git clone https://ghproxy.com/https://github.com/TapXWorld/ChinaTextbook.git</code>
            </div>
            <div class="bg-muted p-4 rounded-lg text-sm">
              <div class="mb-2 font-semibold">备用加速：</div>
              <code class="text-accent">git clone https://ghps.cc/https://github.com/TapXWorld/ChinaTextbook.git</code>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Notice -->
    <div id="notice" class="rounded-lg border border-border bg-surface p-6">
      <h2 class="mb-4 text-2xl font-bold text-accent">⚠️ 使用说明</h2>
      <ul class="text-sm text-skin-muted space-y-2">
        <li>• 教材文件仅供个人学习使用，请勿用于商业用途</li>
        <li>• 仓库大小约 43.5GB，下载需要较长时间</li>
        <li>• 建议使用 Git 克隆或下载 ZIP 压缩包</li>
        <li>• 如遇到下载问题，请检查网络连接</li>
        <li>• 教材内容来源于 ChinaTextbook 仓库，本站仅提供下载指引</li>
      </ul>
    </div>
  </section>
</Main>
