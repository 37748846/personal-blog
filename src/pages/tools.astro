---
import "@pagefind/default-ui/css/ui.css";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const backUrl = SITE.showBackButton ? `${Astro.url.pathname}` : "/";
---
<Main pageTitle="免费工具" pageDesc="免费在线工具集合，包括文本工具、图片工具、开发工具等">
  <section class="mx-auto max-w-3xl px-4 py-8 sm:px-6 sm:py-12">
    <h1 class="mb-8 text-4xl font-bold text-accent sm:text-5xl">免费工具</h1>

    <p class="mb-8 text-lg text-skin-muted">
      这里收集了各种免费在线工具，帮助你提高工作效率。
    </p>

    <!-- Quick Navigation -->
    <div class="mb-8 rounded-lg border border-border bg-surface p-4">
      <nav class="flex flex-wrap justify-center gap-4">
        <a
          href="#ai-tools"
          class="px-4 py-2 bg-muted text-foreground rounded-lg hover:bg-accent/10 transition-colors"
        >
          🤖 AI工具
        </a>
        <a
          href="#local-tools"
          class="px-4 py-2 bg-muted text-foreground rounded-lg hover:bg-accent/10 transition-colors"
        >
          🛠️ 本地工具
        </a>
      </nav>
    </div>

    <!-- AI 工具部分 -->
    <div id="ai-tools" class="mb-8 rounded-lg border border-border bg-surface p-6">
      <h2 class="mb-4 text-2xl font-bold text-accent flex items-center">
        <span class="mr-2">🤖</span>
        免费AI工具
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <a
          href="https://chat.openai.com"
          target="_blank"
          rel="noopener noreferrer"
          class="block p-4 rounded-lg border border-border hover:border-accent transition-colors"
        >
          <div class="flex items-start space-x-3">
            <div class="text-3xl">🤖</div>
            <div class="flex-1">
              <h3 class="text-base font-semibold mb-1">ChatGPT</h3>
              <p class="text-xs text-skin-muted mb-1">OpenAI 的 AI 聊天助手</p>
              <div class="flex items-center space-x-2">
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-accent/10 text-accent rounded">
                  AI 聊天
                </span>
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-muted text-foreground rounded">
                  外部链接
                </span>
              </div>
            </div>
          </div>
        </a>

        <a
          href="https://claude.ai"
          target="_blank"
          rel="noopener noreferrer"
          class="block p-4 rounded-lg border border-border hover:border-accent transition-colors"
        >
          <div class="flex items-start space-x-3">
            <div class="text-3xl">🧠</div>
            <div class="flex-1">
              <h3 class="text-base font-semibold mb-1">Claude</h3>
              <p class="text-xs text-skin-muted mb-1">Anthropic 的 AI 助手</p>
              <div class="flex items-center space-x-2">
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-accent/10 text-accent rounded">
                  AI 聊天
                </span>
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-muted text-foreground rounded">
                  外部链接
                </span>
              </div>
            </div>
          </div>
        </a>

        <a
          href="https://gemini.google.com"
          target="_blank"
          rel="noopener noreferrer"
          class="block p-4 rounded-lg border border-border hover:border-accent transition-colors"
        >
          <div class="flex items-start space-x-3">
            <div class="text-3xl">✨</div>
            <div class="flex-1">
              <h3 class="text-base font-semibold mb-1">Gemini</h3>
              <p class="text-xs text-skin-muted mb-1">Google 的 AI 助手</p>
              <div class="flex items-center space-x-2">
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-accent/10 text-accent rounded">
                  AI 聊天
                </span>
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-muted text-foreground rounded">
                  外部链接
                </span>
              </div>
            </div>
          </div>
        </a>

        <a
          href="https://www.deepseek.com"
          target="_blank"
          rel="noopener noreferrer"
          class="block p-4 rounded-lg border border-border hover:border-accent transition-colors"
        >
          <div class="flex items-start space-x-3">
            <div class="text-3xl">🔎</div>
            <div class="flex-1">
              <h3 class="text-base font-semibold mb-1">DeepSeek</h3>
              <p class="text-xs text-skin-muted mb-1">国产 AI 搜索引擎</p>
              <div class="flex items-center space-x-2">
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-accent/10 text-accent rounded">
                  AI 搜索
                </span>
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-muted text-foreground rounded">
                  外部链接
                </span>
              </div>
            </div>
          </div>
        </a>

        <a
          href="https://www.perplexity.ai"
          target="_blank"
          rel="noopener noreferrer"
          class="block p-4 rounded-lg border border-border hover:border-accent transition-colors"
        >
          <div class="flex items-start space-x-3">
            <div class="text-3xl">🔍</div>
            <div class="flex-1">
              <h3 class="text-base font-semibold mb-1">Perplexity</h3>
              <p class="text-xs text-skin-muted mb-1">AI 驱动的搜索引擎</p>
              <div class="flex items-center space-x-2">
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-accent/10 text-accent rounded">
                  AI 搜索
                </span>
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-muted text-foreground rounded">
                  外部链接
                </span>
              </div>
            </div>
          </div>
        </a>

        <a
          href="https://huggingface.co"
          target="_blank"
          rel="noopener noreferrer"
          class="block p-4 rounded-lg border border-border hover:border-accent transition-colors"
        >
          <div class="flex items-start space-x-3">
            <div class="text-3xl">🤗</div>
            <div class="flex-1">
              <h3 class="text-base font-semibold mb-1">Hugging Face</h3>
              <p class="text-xs text-skin-muted mb-1">开源 AI 模型平台</p>
              <div class="flex items-center space-x-2">
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-accent/10 text-accent rounded">
                  AI 模型
                </span>
                <span class="inline-block px-2 py-0.5 text-xs font-medium bg-muted text-foreground rounded">
                  外部链接
                </span>
              </div>
            </div>
          </div>
        </a>
      </div>
    </div>

    <!-- 本地工具部分 -->
    <div id="local-tools" class="mb-8 rounded-lg border border-border bg-surface p-6">
      <h2 class="mb-4 text-2xl font-bold text-accent">本地工具</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="p-4 rounded-lg border border-border">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">🔐</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-1">Base64 编码/解码</h3>
              <p class="text-sm text-skin-muted mb-2">在线 Base64 编码和解码工具</p>
              <span class="inline-block px-2 py-1 text-xs font-medium bg-accent/10 text-accent rounded">
                编码转换
              </span>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-lg border border-border">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">🔗</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-1">URL 编码/解码</h3>
              <p class="text-sm text-skin-muted mb-2">在线 URL 编码和解码工具</p>
              <span class="inline-block px-2 py-1 text-xs font-medium bg-accent/10 text-accent rounded">
                编码转换
              </span>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-lg border border-border">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">📝</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-1">JSON 格式化</h3>
              <p class="text-sm text-skin-muted mb-2">在线 JSON 格式化和验证工具</p>
              <span class="inline-block px-2 py-1 text-xs font-medium bg-accent/10 text-accent rounded">
                格式化
              </span>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-lg border border-border">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">⏰</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-1">时间戳转换</h3>
              <p class="text-sm text-skin-muted mb-2">在线时间戳和日期时间转换工具</p>
              <span class="inline-block px-2 py-1 text-xs font-medium bg-accent/10 text-accent rounded">
                时间工具
              </span>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-lg border border-border">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">🎨</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-1">颜色转换</h3>
              <p class="text-sm text-skin-muted mb-2">HEX、RGB、HSL 颜色格式转换</p>
              <span class="inline-block px-2 py-1 text-xs font-medium bg-accent/10 text-accent rounded">
                颜色工具
              </span>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-lg border border-border">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">🔍</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-1">正则表达式测试</h3>
              <p class="text-sm text-skin-muted mb-2">在线正则表达式测试工具</p>
              <span class="inline-block px-2 py-1 text-xs font-medium bg-accent/10 text-accent rounded">
                开发工具
              </span>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-lg border border-border">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">📱</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-1">二维码生成</h3>
              <p class="text-sm text-skin-muted mb-2">在线生成二维码工具</p>
              <span class="inline-block px-2 py-1 text-xs font-medium bg-accent/10 text-accent rounded">
                生成工具
              </span>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-lg border border-border">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">🖼️</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-1">图片压缩</h3>
              <p class="text-sm text-skin-muted mb-2">在线图片压缩工具</p>
              <span class="inline-block px-2 py-1 text-xs font-medium bg-accent/10 text-accent rounded">
                图片工具
              </span>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-lg border border-border">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">✂️</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-1">图片裁剪</h3>
              <p class="text-sm text-skin-muted mb-2">在线图片裁剪工具</p>
              <span class="inline-block px-2 py-1 text-xs font-medium bg-accent/10 text-accent rounded">
                图片工具
              </span>
            </div>
          </div>
        </div>

        <div class="p-4 rounded-lg border border-border">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">🔄</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold mb-1">格式转换</h3>
              <p class="text-sm text-skin-muted mb-2">PNG、JPG、WebP 格式转换</p>
              <span class="inline-block px-2 py-1 text-xs font-medium bg-accent/10 text-accent rounded">
                图片工具
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="rounded-lg border border-border bg-surface p-6">
      <h2 class="mb-4 text-2xl font-bold text-accent">工具特点</h2>
      <ul class="space-y-2">
        <li class="flex items-center">
          <span class="mr-2 text-accent">✓</span>
          <span>完全免费</span>
        </li>
        <li class="flex items-center">
          <span class="mr-2 text-accent">✓</span>
          <span>无需注册</span>
        </li>
        <li class="flex items-center">
          <span class="mr-2 text-accent">✓</span>
          <span>本地处理，保护隐私</span>
        </li>
        <li class="flex items-center">
          <span class="mr-2 text-accent">✓</span>
          <span>响应式设计，支持移动端</span>
        </li>
        <li class="flex items-center">
          <span class="mr-2 text-accent">✓</span>
          <span>快速高效</span>
        </li>
      </ul>
    </div>
  </section>
</Main>
