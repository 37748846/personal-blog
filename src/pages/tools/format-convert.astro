---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="格式转换" description="PNG、JPG、WebP 格式转换工具">
  <main class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-blue-600 hover:text-blue-800">← 返回工具列表</a>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">
      格式转换
    </h1>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="text-center py-12">
        <div class="text-6xl mb-4">🔄</div>
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">
          功能开发中
        </h2>
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          格式转换功能正在开发中，敬请期待
        </p>
        <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 text-left">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">计划功能</h3>
          <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-1">
            <li>• 支持 PNG、JPG、WebP 互转</li>
            <li>• 批量转换支持</li>
            <li>• 自定义输出质量</li>
            <li>• 实时预览转换效果</li>
            <li>• 对比原图和转换后图片</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 mt-6">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-2">使用说明</h3>
      <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-1">
        <li>• 上传图片文件进行格式转换</li>
        <li>• 选择目标格式（PNG、JPG、WebP）</li>
        <li>• 调整输出质量参数</li>
        <li>• 预览转换效果</li>
        <li>• 下载转换后的图片</li>
        <li>• 所有处理在本地完成，数据不会上传到服务器</li>
      </ul>
    </div>
  </main>
</Layout>
