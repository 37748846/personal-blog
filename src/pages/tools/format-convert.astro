---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="格式转换" description="PNG、JPG、WebP 格式转换工具">
  <main class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-blue-600 hover:text-blue-800">← 返回工具列表</a>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">
      格式转换
    </h1>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 space-y-6">
      {/* 上传区域 */}
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          选择图片
        </label>
        <div
          id="drop-zone"
          class="border-2 border-dashed border-gray-300 dark:border-gray-600 rounded-lg p-8 text-center cursor-pointer hover:border-blue-500 transition-colors"
        >
          <div class="text-4xl mb-2">📁</div>
          <p class="text-gray-600 dark:text-gray-400 mb-2">
            拖拽图片到此处或点击上传
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-500">
            支持 JPG、PNG、WebP 格式
          </p>
          <input
            type="file"
            id="file-input"
            accept="image/jpeg,image/png,image/webp"
            multiple
            class="hidden"
          />
        </div>
      </div>

      {/* 转换设置 */}
      <div id="settings" class="hidden space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            目标格式
          </label>
          <div class="grid grid-cols-3 gap-2">
            <button
              data-format="image/jpeg"
              class="format-btn px-3 py-2 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-700"
            >
              JPG
            </button>
            <button
              data-format="image/png"
              class="format-btn px-3 py-2 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-700"
            >
              PNG
            </button>
            <button
              data-format="image/webp"
              class="format-btn px-3 py-2 border border-gray-300 dark:border-gray-600 rounded hover:bg-gray-100 dark:hover:bg-gray-700"
            >
              WebP
            </button>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            输出质量: <span id="quality-value">90</span>%
          </label>
          <input
            type="range"
            id="quality-slider"
            min="10"
            max="100"
            value="90"
            class="w-full"
          />
        </div>

        <button
          id="convert-btn"
          class="w-full px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700"
        >
          转换图片
        </button>
      </div>

      <!-- 文件列表 -->
      <div id="file-list" class="hidden space-y-4">
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300">
          文件列表 (<span id="file-count">0</span>)
        </h3>
        <div id="files-container" class="space-y-2"></div>

        <button
          id="download-all-btn"
          class="w-full px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700"
        >
          下载所有转换后的图片
        </button>
      </div>
    </div>

    <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 mt-6">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-2">使用说明</h3>
      <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-1">
        <li>• 上传图片文件进行格式转换</li>
        <li>• 支持批量转换多个图片</li>
        <li>• 选择目标格式（JPG、PNG、WebP）</li>
        <li>• 调整输出质量参数</li>
        <li>• 预览转换效果</li>
        <li>• 下载转换后的图片</li>
        <li>• 所有处理在本地完成，数据不会上传到服务器</li>
      </ul>
    </div>
  </main>
</Layout>

<script>
  const dropZone = document.getElementById('drop-zone') as HTMLDivElement;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const settingsDiv = document.getElementById('settings') as HTMLDivElement;
  const fileListDiv = document.getElementById('file-list') as HTMLDivElement;
  const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement;
  const qualityValue = document.getElementById('quality-value') as HTMLElement;
  const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement;
  const downloadAllBtn = document.getElementById('download-all-btn') as HTMLButtonElement;
  const fileCountSpan = document.getElementById('file-count') as HTMLElement;
  const filesContainer = document.getElementById('files-container') as HTMLDivElement;

  let files: File[] = [];
  let targetFormat: string = 'image/jpeg';
  let convertedBlobs: { name: string; blob: Blob }[] = [];

  // 拖拽上传
  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-blue-500');
  });

  dropZone?.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-blue-500');
  });

  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-blue-500');
    const droppedFiles = e.dataTransfer?.files;
    if (droppedFiles && droppedFiles.length > 0) {
      handleFiles(Array.from(droppedFiles));
    }
  });

  // 点击上传
  dropZone?.addEventListener('click', () => {
    fileInput?.click();
  });

  fileInput?.addEventListener('change', (e) => {
    const selectedFiles = (e.target as HTMLInputElement).files;
    if (selectedFiles && selectedFiles.length > 0) {
      handleFiles(Array.from(selectedFiles));
    }
  });

  // 格式按钮
  document.querySelectorAll('.format-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      targetFormat = btn.getAttribute('data-format') || 'image/jpeg';
      document.querySelectorAll('.format-btn').forEach(b => {
        b.classList.remove('bg-blue-500', 'text-white');
      });
      btn.classList.add('bg-blue-500', 'text-white');
    });
  });

  // 质量滑块
  qualitySlider?.addEventListener('input', (e) => {
    if (qualityValue) {
      qualityValue.textContent = (e.target as HTMLInputElement).value;
    }
  });

  function handleFiles(newFiles: File[]) {
    const imageFiles = newFiles.filter(file => file.type.startsWith('image/'));
    files = [...files, ...imageFiles];

    if (files.length > 0) {
      settingsDiv?.classList.remove('hidden');
      fileListDiv?.classList.remove('hidden');
      updateFileList();
    }
  }

  function updateFileList() {
    if (!filesContainer || !fileCountSpan) return;

    filesContainer.innerHTML = '';
    fileCountSpan.textContent = files.length.toString();

    files.forEach((file, index) => {
      const div = document.createElement('div');
      div.className = 'flex items-center justify-between p-3 bg-gray-50 dark:bg-gray-900 rounded';
      div.innerHTML = `
        <div class="flex-1">
          <p class="text-sm font-medium text-gray-900 dark:text-white">${file.name}</p>
          <p class="text-xs text-gray-600 dark:text-gray-400">${formatFileSize(file.size)}</p>
        </div>
        <button class="remove-btn px-2 py-1 text-red-600 hover:text-red-800" data-index="${index}">
          ✕
        </button>
      `;
      filesContainer.appendChild(div);
    });

    // 添加删除按钮事件
    document.querySelectorAll('.remove-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const index = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0', 10);
        files.splice(index, 1);
        updateFileList();

        if (files.length === 0) {
          settingsDiv?.classList.add('hidden');
          fileListDiv?.classList.add('hidden');
        }
      });
    });
  }

  function formatFileSize(bytes: number): string {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
  }

  async function convertImages() {
    if (files.length === 0) return;

    const quality = parseInt(qualitySlider?.value || '90', 10) / 100;
    convertedBlobs = [];

    for (const file of files) {
      try {
        const blob = await convertImage(file, targetFormat, quality);
        const extension = targetFormat === 'image/jpeg' ? 'jpg' : 
                         targetFormat === 'image/png' ? 'png' : 'webp';
        const newName = file.name.replace(/\.[^/.]+$/, `.${extension}`);
        convertedBlobs.push({ name: newName, blob });
      } catch (error) {
        console.error('转换失败:', file.name, error);
      }
    }

    alert(`成功转换 ${convertedBlobs.length} 个图片`);
  }

  function convertImage(file: File, format: string, quality: number): Promise<Blob> {
    return new Promise((resolve, reject) => {
      const img = new Image();
      const reader = new FileReader();

      reader.onload = (e) => {
        img.src = e.target?.result as string;
      };

      img.onload = () => {
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');

        if (!ctx) {
          reject(new Error('无法获取 canvas 上下文'));
          return;
        }

        canvas.width = img.width;
        canvas.height = img.height;

        // 绘制图片
        ctx.drawImage(img, 0, 0);

        // 转换格式
        canvas.toBlob((blob) => {
          if (blob) {
            resolve(blob);
          } else {
            reject(new Error('转换失败'));
          }
        }, format, quality);
      };

      img.onerror = () => {
        reject(new Error('图片加载失败'));
      };

      reader.readAsDataURL(file);
    });
  }

  function downloadAll() {
    if (convertedBlobs.length === 0) {
      alert('请先转换图片');
      return;
    }

    convertedBlobs.forEach(({ name, blob }) => {
      const link = document.createElement('a');
      link.download = name;
      link.href = URL.createObjectURL(blob);
      link.click();
    });
  }

  convertBtn?.addEventListener('click', convertImages);
  downloadAllBtn?.addEventListener('click', downloadAll);
</script>
