---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
---

<Layout title="Base64 编码/解码" description="在线 Base64 编码和解码工具">
  <Header />
  <main class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-blue-600 hover:text-blue-800">← 返回工具列表</a>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">
      Base64 编码/解码
    </h1>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 space-y-4">
      <div class="flex space-x-4 mb-4">
        <button
          id="encode-btn"
          class="px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-700"
        >
          编码
        </button>
        <button
          id="decode-btn"
          class="px-4 py-2 rounded bg-gray-200 text-gray-700 hover:bg-gray-300"
        >
          解码
        </button>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          输入
        </label>
        <textarea
          id="input"
          placeholder="输入要编码的文本"
          class="w-full h-32 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
        ></textarea>
      </div>

      <div class="flex space-x-2">
        <button
          id="convert-btn"
          class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700"
        >
          编码
        </button>
        <button
          id="clear-btn"
          class="px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300"
        >
          清空
        </button>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          输出
        </label>
        <textarea
          id="output"
          readonly
          class="w-full h-32 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-gray-50 dark:bg-gray-900 focus:outline-none text-gray-900 dark:text-white"
        ></textarea>
      </div>

      <div class="flex space-x-2">
        <button
          id="copy-btn"
          disabled
          class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 disabled:bg-gray-300 disabled:cursor-not-allowed"
        >
          复制结果
        </button>
      </div>
    </div>

    <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 mt-6">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-2">使用说明</h3>
      <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-1">
        <li>• 编码：将普通文本转换为 Base64 格式</li>
        <li>• 解码：将 Base64 格式还原为普通文本</li>
        <li>• 支持中文和特殊字符</li>
        <li>• 所有处理在本地完成，数据不会上传到服务器</li>
      </ul>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  let mode = 'encode';

  const encodeBtn = document.getElementById('encode-btn') as HTMLButtonElement;
  const decodeBtn = document.getElementById('decode-btn') as HTMLButtonElement;
  const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const input = document.getElementById('input') as HTMLTextAreaElement;
  const output = document.getElementById('output') as HTMLTextAreaElement;

  function updateMode(newMode: string) {
    mode = newMode;
    if (mode === 'encode') {
      if (encodeBtn) encodeBtn.className = 'px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-700';
      if (decodeBtn) decodeBtn.className = 'px-4 py-2 rounded bg-gray-200 text-gray-700 hover:bg-gray-300';
      if (convertBtn) convertBtn.textContent = '编码';
      if (input) input.placeholder = '输入要编码的文本';
    } else {
      if (decodeBtn) decodeBtn.className = 'px-4 py-2 rounded bg-blue-600 text-white hover:bg-blue-700';
      if (encodeBtn) encodeBtn.className = 'px-4 py-2 rounded bg-gray-200 text-gray-700 hover:bg-gray-300';
      if (convertBtn) convertBtn.textContent = '解码';
      if (input) input.placeholder = '输入要解码的 Base64';
    }
  }

  function handleConvert() {
    try {
      const inputValue = input?.value || '';
      if (mode === 'encode') {
        const encoded = btoa(unescape(encodeURIComponent(inputValue)));
        if (output) output.value = encoded;
      } else {
        const decoded = decodeURIComponent(escape(atob(inputValue)));
        if (output) output.value = decoded;
      }
      if (copyBtn) copyBtn.disabled = false;
    } catch {
      if (output) output.value = '错误：输入格式不正确';
      if (copyBtn) copyBtn.disabled = true;
    }
  }

  function handleCopy() {
    try {
      navigator.clipboard.writeText(output?.value || '');
      alert('已复制到剪贴板');
    } catch (error) {
      alert('复制失败');
    }
  }

  function handleClear() {
    if (input) input.value = '';
    if (output) output.value = '';
    if (copyBtn) copyBtn.disabled = true;
  }

  encodeBtn?.addEventListener('click', () => updateMode('encode'));
  decodeBtn?.addEventListener('click', () => updateMode('decode'));
  convertBtn?.addEventListener('click', handleConvert);
  clearBtn?.addEventListener('click', handleClear);
  copyBtn?.addEventListener('click', handleCopy);
</script>
