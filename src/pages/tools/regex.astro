---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="正则表达式测试" description="在线正则表达式测试工具">
  <main class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-6">
      <a href="/tools" class="text-blue-600 hover:text-blue-800">← 返回工具列表</a>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">
      正则表达式测试
    </h1>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 space-y-6">
      {/* 正则表达式输入 */}
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          正则表达式
        </label>
        <div class="flex space-x-2">
          <input
            type="text"
            id="pattern-input"
            placeholder="例如: \\b\\w+@\\w+\\.\\w+\\b"
            class="flex-1 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
          />
          <button
            id="sample-btn"
            class="px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300"
          >
            示例
          </button>
        </div>
      </div>

      {/* 标志位 */}
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          标志位
        </label>
        <div class="flex space-x-4">
          <label class="flex items-center space-x-2">
            <input
              type="checkbox"
              id="flag-g"
              checked
              class="rounded"
            />
            <span class="text-sm text-gray-700 dark:text-gray-300">g (全局)</span>
          </label>
          <label class="flex items-center space-x-2">
            <input
              type="checkbox"
              id="flag-i"
              class="rounded"
            />
            <span class="text-sm text-gray-700 dark:text-gray-300">i (忽略大小写)</span>
          </label>
          <label class="flex items-center space-x-2">
            <input
              type="checkbox"
              id="flag-m"
              class="rounded"
            />
            <span class="text-sm text-gray-700 dark:text-gray-300">m (多行)</span>
          </label>
        </div>
      </div>

      {/* 测试文本 */}
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          测试文本
        </label>
        <textarea
          id="text-input"
          placeholder="输入要测试的文本"
          class="w-full h-32 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
        ></textarea>
      </div>

      {/* 测试按钮 */}
      <button
        id="test-btn"
        class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700"
      >
        测试
      </button>

      {/* 错误信息 */}
      <div id="error" class="hidden bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-md p-3">
        <p class="text-sm text-red-800 dark:text-red-300"></p>
      </div>

      {/* 匹配结果 */}
      <div id="results" class="hidden">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          匹配结果 (<span id="match-count">0</span> 个)
        </label>
        <div id="matches-container" class="space-y-2"></div>
        <button
          id="copy-all-btn"
          class="mt-2 px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700"
        >
          复制所有结果
        </button>
      </div>
    </div>

    <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 mt-6">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-2">使用说明</h3>
      <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-1">
        <li>• 输入正则表达式和测试文本进行匹配测试</li>
        <li>• g: 全局匹配，查找所有匹配项</li>
        <li>• i: 忽略大小写</li>
        <li>• m: 多行模式，^ 和 $ 匹配每行的开始和结束</li>
        <li>• 所有处理在本地完成，数据不会上传到服务器</li>
      </ul>
    </div>
  </main>
</Layout>

<script>
  const patternInput = document.getElementById('pattern-input') as HTMLInputElement;
  const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
  const flagG = document.getElementById('flag-g') as HTMLInputElement;
  const flagI = document.getElementById('flag-i') as HTMLInputElement;
  const flagM = document.getElementById('flag-m') as HTMLInputElement;
  const testBtn = document.getElementById('test-btn') as HTMLButtonElement;
  const sampleBtn = document.getElementById('sample-btn') as HTMLButtonElement;
  const copyAllBtn = document.getElementById('copy-all-btn') as HTMLButtonElement;
  const errorDiv = document.getElementById('error') as HTMLDivElement;
  const resultsDiv = document.getElementById('results') as HTMLDivElement;
  const matchCountSpan = document.getElementById('match-count') as HTMLElement;
  const matchesContainer = document.getElementById('matches-container') as HTMLDivElement;

  let matches: string[] = [];

  function getFlags(): string {
    let flags = '';
    if (flagG?.checked) flags += 'g';
    if (flagI?.checked) flags += 'i';
    if (flagM?.checked) flags += 'm';
    return flags;
  }

  function showError(message: string) {
    const errorP = errorDiv?.querySelector('p');
    if (errorP) {
      errorP.textContent = message;
      errorDiv?.classList.remove('hidden');
    }
  }

  function hideError() {
    errorDiv?.classList.add('hidden');
  }

  function showResults() {
    resultsDiv?.classList.remove('hidden');
    if (matchCountSpan) {
      matchCountSpan.textContent = matches.length.toString();
    }
  }

  function hideResults() {
    resultsDiv?.classList.add('hidden');
  }

  function handleTest() {
    try {
      const pattern = patternInput?.value || '';
      const text = textInput?.value || '';
      const flags = getFlags();

      if (!pattern) {
        showError('请输入正则表达式');
        hideResults();
        return;
      }

      const regex = new RegExp(pattern, flags);
      matches = [];

      if (flags.includes('g')) {
        let match;
        while ((match = regex.exec(text)) !== null) {
          matches.push(match[0]);
        }
      } else {
        const match = regex.exec(text);
        if (match) {
          matches.push(match[0]);
        }
      }

      hideError();
      showResults();

      // 显示匹配结果
      if (matchesContainer) {
        matchesContainer.innerHTML = '';
        matches.forEach((match, index) => {
          const div = document.createElement('div');
          div.className = 'p-2 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded';
          div.innerHTML = `<code class="text-sm text-gray-900 dark:text-white">${match}</code>`;
          matchesContainer.appendChild(div);
        });
      }
    } catch (err) {
      const message = err instanceof Error ? err.message : String(err);
      showError(`正则表达式错误: ${message}`);
      hideResults();
    }
  }

  function handleLoadSample() {
    if (patternInput) patternInput.value = '\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b';
    if (flagG) flagG.checked = true;
    if (flagI) flagI.checked = false;
    if (flagM) flagM.checked = false;
    if (textInput) textInput.value = '联系我们：support@example.com 或 sales@example.com';
  }

  function handleCopyAll() {
    try {
      navigator.clipboard.writeText(matches.join('\n'));
      alert('已复制到剪贴板');
    } catch (error) {
      alert('复制失败');
    }
  }

  testBtn?.addEventListener('click', handleTest);
  sampleBtn?.addEventListener('click', handleLoadSample);
  copyAllBtn?.addEventListener('click', handleCopyAll);
</script>
