---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---


<Layout title="在线工具" description="提供图片处理、编码转换、格式化等免费在线工具">
  <Header />
  <main class="max-w-6xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
        在线工具
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        提供图片处理、编码转换、格式化等免费在线工具
      </p>
    </div>

    <!-- 本地工具部分 -->
    <div class="space-y-8">
      <h2 class="text-xl font-semibold text-gray-800 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">
        本地工具
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/tools/base64" class="block p-6 bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-md transition-shadow">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">🔐</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">
                Base64 编码/解码
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">
                在线 Base64 编码和解码工具
              </p>
              <span class="inline-block px-2 py-1 text-xs font-medium text-blue-800 dark:text-blue-200 bg-blue-100 dark:bg-blue-900 rounded">
                编码转换
              </span>
            </div>
          </div>
        </a>

        <a href="/tools/url" class="block p-6 bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-md transition-shadow">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">🔗</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">
                URL 编码/解码
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">
                在线 URL 编码和解码工具
              </p>
              <span class="inline-block px-2 py-1 text-xs font-medium text-blue-800 dark:text-blue-200 bg-blue-100 dark:bg-blue-900 rounded">
                编码转换
              </span>
            </div>
          </div>
        </a>

        <a href="/tools/json" class="block p-6 bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-md transition-shadow">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">📝</div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">
                JSON 格式化
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">
                在线 JSON 格式化和验证工具
