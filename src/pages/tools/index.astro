              </span>
            </div>
          </div>
        </a>

        <a href="/tools/timestamp" class="block p-6 bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-md transition-shadow">
          <div class="flex items-start space-x-4">
            <div class="text-4xl">⏰</div>
            <div class="flex-1">
