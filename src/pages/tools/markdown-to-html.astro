---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
---

<Layout title="Markdown 转 HTML" description="在线 Markdown 转 HTML 工具">
  <Header />
  <main class="app-layout py-8">
    <div class="mb-6">
      <a href="/tools" class="text-blue-600 hover:text-blue-800">← 返回工具列表</a>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">
      Markdown 转 HTML
    </h1>

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          Markdown 输入
        </label>
        <textarea
          id="markdown-input"
          placeholder="输入 Markdown 文本..."
          class="w-full h-48 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white font-mono text-sm"
        ></textarea>
      </div>

      <div class="flex space-x-2">
        <button
          id="convert-btn"
          class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700"
        >
          转换为 HTML
        </button>
        <button
          id="clear-btn"
          class="px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300"
        >
          清空
        </button>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          HTML 输出
        </label>
        <textarea
          id="html-output"
          readonly
          class="w-full h-48 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md bg-gray-50 dark:bg-gray-900 focus:outline-none text-gray-900 dark:text-white font-mono text-sm"
        ></textarea>
      </div>

      <div class="flex space-x-2">
        <button
          id="copy-btn"
          disabled
          class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 disabled:bg-gray-300 disabled:cursor-not-allowed"
        >
          复制 HTML
        </button>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          预览
        </label>
        <div
          id="preview"
          class="w-full min-h-32 p-4 border border-gray-300 dark:border-gray-600 rounded-md bg-white dark:bg-gray-700 prose dark:prose-invert max-w-none"
        ></div>
      </div>
    </div>

    <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-4 mt-6">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-2">使用说明</h3>
      <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-1">
        <li>• 输入 Markdown 格式的文本</li>
        <li>• 点击"转换为 HTML"按钮</li>
        <li>• 查看转换后的 HTML 代码</li>
        <li>• 预览渲染效果</li>
        <li>• 复制 HTML 代码到剪贴板</li>
        <li>• 所有处理在本地完成，数据不会上传到服务器</li>
      </ul>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const markdownInput = document.getElementById('markdown-input') as HTMLTextAreaElement;
  const htmlOutput = document.getElementById('html-output') as HTMLTextAreaElement;
  const preview = document.getElementById('preview') as HTMLDivElement;

  function markdownToHtml(markdown: string): string {
    let html = markdown;

    // 标题
    html = html.replace(/^###### (.*$)/gim, '<h6>$1</h6>');
    html = html.replace(/^##### (.*$)/gim, '<h5>$1</h5>');
    html = html.replace(/^#### (.*$)/gim, '<h4>$1</h4>');
    html = html.replace(/^### (.*$)/gim, '<h3>$1</h3>');
    html = html.replace(/^## (.*$)/gim, '<h2>$1</h2>');
    html = html.replace(/^# (.*$)/gim, '<h1>$1</h1>');

    // 粗体和斜体
    html = html.replace(/\*\*\*(.*?)\*\*\*/gim, '<strong><em>$1</em></strong>');
    html = html.replace(/\*\*(.*?)\*\*/gim, '<strong>$1</strong>');
    html = html.replace(/\*(.*?)\*/gim, '<em>$1</em>');
    html = html.replace(/___(.*?)___/gim, '<strong><em>$1</em></strong>');
    html = html.replace(/__(.*?)__/gim, '<strong>$1</strong>');
    html = html.replace(/_(.*?)_/gim, '<em>$1</em>');

    // 删除线
    html = html.replace(/~~(.*?)~~/gim, '<del>$1</del>');

    // 代码
    html = html.replace(/```([\s\S]*?)```/gim, '<pre><code>$1</code></pre>');
    html = html.replace(/`([^`]+)`/gim, '<code>$1</code>');

    // 链接
    html = html.replace(/\[(.*?)\]\((.*?)\)/gim, '<a href="$2" target="_blank">$1</a>');

    // 图片
    html = html.replace(/!\[(.*?)\]\((.*?)\)/gim, '<img src="$2" alt="$1" />');

    // 引用
    html = html.replace(/^> (.*$)/gim, '<blockquote>$1</blockquote>');

    // 水平线
    html = html.replace(/^---$/gim, '<hr />');
    html = html.replace(/^\*\*\*$/gim, '<hr />');

    // 换行
    html = html.replace(/\n/gim, '<br />');

    return html;
  }

  function handleConvert() {
    const markdown = markdownInput?.value || '';
    const html = markdownToHtml(markdown);

    if (htmlOutput) htmlOutput.value = html;
    if (preview) preview.innerHTML = html;
    if (copyBtn) copyBtn.disabled = false;
  }

  function handleClear() {
    if (markdownInput) markdownInput.value = '';
    if (htmlOutput) htmlOutput.value = '';
    if (preview) preview.innerHTML = '';
    if (copyBtn) copyBtn.disabled = true;
  }

  function handleCopy() {
    try {
      navigator.clipboard.writeText(htmlOutput?.value || '');
      alert('已复制到剪贴板');
    } catch (error) {
      alert('复制失败');
    }
  }

  convertBtn?.addEventListener('click', handleConvert);
  clearBtn?.addEventListener('click', handleClear);
  copyBtn?.addEventListener('click', handleCopy);
</script>
